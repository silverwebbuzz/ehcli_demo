# Front controller — route all non-file/non-directory requests to index.php
<IfModule mod_rewrite.c>
    RewriteEngine On

    # If the app lives in a subfolder, set RewriteBase to that folder, e.g. RewriteBase /app/
    # RewriteBase /

    # Don't rewrite requests that map to a real file or directory
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Everything else goes to the front controller
    RewriteRule ^ index.php [L]
</IfModule>

# Block direct access to sensitive files
<FilesMatch "^\.env|composer\.(json|lock)$">
    Require all denied
</FilesMatch>
